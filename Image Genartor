<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Angel Nunez | Systems Architect Work Sample</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Inter:wght@300;400;600&family=Space+Mono&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #3b82f6;
            --bg: #000000;
        }

        body {
            background-color: var(--bg);
            color: #fff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        /* Immersive Layout - No Boxes */
        section {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 10%;
        }

        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3.5rem, 12vw, 10rem);
            line-height: 0.85;
            letter-spacing: -0.05em;
            text-transform: uppercase;
        }

        .outline-text {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);
            color: transparent;
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .outline-text:hover {
            -webkit-text-stroke: 1px var(--accent);
            color: rgba(59, 130, 246, 0.05);
        }

        .font-signature { font-family: 'Dancing Script', cursive; }
        .font-mono { font-family: 'Space Mono', monospace; }

        /* Bottom Nav - Icon-free, Work Sample Focused */
        .bottom-nav {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(10, 10, 10, 0.6);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            display: flex;
            padding: 8px;
            gap: 4px;
            z-index: 100;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .nav-item {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 14px 4px;
            border-radius: 18px;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.4);
            white-space: nowrap;
        }

        .nav-item.active {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            box-shadow: inset 0 0 10px rgba(255,255,255,0.05);
        }

        .divider {
            height: 1px;
            background: linear-gradient(to right, var(--accent), transparent);
            width: 150px;
            margin: 2.5rem 0;
            opacity: 0.5;
        }

        ::-webkit-scrollbar { display: none; }
        
        /* Smooth Scroll */
        html { scroll-behavior: smooth; }
    </style>
</head>
<body>

    <div id="canvas-container"></div>

    <!-- Top Branding -->
    <header class="fixed top-0 w-full p-8 flex justify-between items-center z-50">
        <div class="flex items-center gap-4">
             <div class="w-11 h-11 bg-white rounded-2xl flex items-center justify-center rotate-6 shadow-xl">
                <span class="text-black font-black text-xl">AN</span>
            </div>
            <div class="hidden sm:block">
                <p class="font-bold text-sm tracking-tight leading-none mb-1 uppercase">Angel Nunez</p>
                <p class="text-[9px] font-mono opacity-40 uppercase tracking-widest">Systems Designer</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
             <div class="px-4 py-2 bg-white/5 rounded-full border border-white/10 text-[9px] font-mono opacity-50 uppercase tracking-widest">
                Verification: ST-992-X
             </div>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="bottom-nav">
        <a href="#home" class="nav-item active" data-tab="home">Home</a>
        <a href="#about" class="nav-item" data-tab="about">About</a>
        <a href="#work" class="nav-item" data-tab="work">Projects</a>
        <a href="#skills" class="nav-item" data-tab="skills">Stack</a>
        <a href="#contact" class="nav-item" data-tab="contact">Work Sample</a>
    </nav>

    <main>
        
        <!-- Hero Section -->
        <section id="home">
            <div class="flex items-baseline gap-4 mb-4">
                <p class="font-mono text-blue-500 text-[10px] uppercase tracking-[0.4em]">Designer // Architect</p>
                <span class="font-signature text-3xl md:text-7xl text-blue-500 transform -rotate-3 opacity-80">Angel Nunez</span>
            </div>
            <h1 class="hero-title">SYSTEMS <br/> <span class="outline-text">ARCHITECT</span></h1>
            <p class="font-mono text-[10px] md:text-xs opacity-40 mt-12 tracking-widest max-w-sm leading-loose border-l-2 border-blue-500 pl-6">
                ARCHITECTING SCALABLE INFRASTRUCTURE THROUGH DATA VISUALIZATION AND HIGH-FIDELITY INTERFACE DESIGN.
            </p>
        </section>

        <!-- About Section -->
        <section id="about">
            <h2 class="text-5xl md:text-8xl font-black font-syne tracking-tighter mb-8 uppercase leading-none">
                THE <br/> <span class="text-blue-500">ENGINE</span>
            </h2>
            <div class="divider"></div>
            <div class="max-w-2xl text-lg md:text-xl opacity-60 leading-relaxed font-light">
                Bridging the gap between <strong>complex data streams</strong> and <strong>human intuition</strong>. By treating operational logic as a design asset, I create systems that don't just function—they communicate. Expertise in high-scale dashboard ecosystems and technical design strategy.
            </div>
        </section>

        <!-- Projects Section -->
        <section id="work">
            <div class="space-y-48">
                <div class="group cursor-pointer">
                    <div class="flex items-center gap-10">
                        <span class="text-[10px] font-mono text-blue-500 opacity-30 group-hover:opacity-100 transition-opacity">001</span>
                        <h3 class="text-6xl md:text-9xl font-black font-syne tracking-tighter uppercase group-hover:text-blue-500 transition-all duration-700">NEURAL HUB</h3>
                    </div>
                    <p class="font-mono text-[10px] opacity-30 mt-8 uppercase ml-24 tracking-[0.2em]">Enterprise Dashboard // Real-time Logic Processing</p>
                </div>
                
                <div class="group cursor-pointer">
                    <div class="flex items-center gap-10">
                        <span class="text-[10px] font-mono text-blue-500 opacity-30 group-hover:opacity-100 transition-opacity">002</span>
                        <h3 class="text-6xl md:text-9xl font-black font-syne tracking-tighter uppercase outline-text group-hover:text-white transition-all duration-700">FLOW GEN</h3>
                    </div>
                    <p class="font-mono text-[10px] opacity-30 mt-8 uppercase ml-24 tracking-[0.2em]">Scaling Strategy // Automated Commission Architecture</p>
                </div>
            </div>
        </section>

        <!-- Stack Section -->
        <section id="skills">
            <h2 class="text-center text-8xl md:text-[16rem] font-black font-syne opacity-5 tracking-tighter absolute left-0 right-0 pointer-events-none select-none">STACK</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-2 max-w-4xl">
                {[
                    ['01', 'Excel Logic Architecture', '◈'],
                    ['02', 'Figma Design Systems', '◈'],
                    ['03', 'Workflow Automation', '◈'],
                    ['04', 'UI/UX Technical Strategy', '◈'],
                    ['05', 'Data Visualization', '◈'],
                    ['06', 'Systems Integration', '◈']
                ].map(([num, title, icon]) => (
                    <div key={title} class="flex justify-between items-center border-b border-white/5 py-8 group hover:border-blue-500/50 transition-colors">
                        <span class="font-mono text-[10px] opacity-30 group-hover:text-blue-500 transition-colors">{num}</span>
                        <span class="font-bold uppercase text-xs md:text-sm tracking-[0.2em]">{title}</span>
                        <span class="text-blue-500 opacity-0 group-hover:opacity-100 transition-opacity">{icon}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- Submission Section -->
        <section id="contact" class="text-center">
            <p class="font-mono text-blue-500 text-[10px] uppercase tracking-[1.5em] mb-12">Official Portfolio Submission</p>
            <h2 class="hero-title outline-text mb-16">WORK SAMPLE</h2>
            <div class="inline-flex items-center gap-12 py-6 px-12 border border-white/10 rounded-full font-mono text-[10px] uppercase tracking-widest bg-white/5 backdrop-blur-md">
                <span>Ref: AN-2024-SYS</span>
                <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                <span>Verified Link</span>
            </div>
        </section>

    </main>

    <script>
        // --- Premium 3D Engine (Three.js) ---
        let scene, camera, renderer, coreGroup;
        const slingers = [];

        function init() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            coreGroup = new THREE.Group();

            // Central Architectural Core (Icosahedron with double wireframe)
            const coreGeom = new THREE.IcosahedronGeometry(7, 1);
            const coreMat = new THREE.MeshBasicMaterial({ 
                color: 0x3b82f6, 
                wireframe: true, 
                transparent: true, 
                opacity: 0.15 
            });
            const coreMesh = new THREE.Mesh(coreGeom, coreMat);
            coreGroup.add(coreMesh);

            const innerCoreGeom = new THREE.IcosahedronGeometry(6.8, 1);
            const innerCoreMat = new THREE.MeshBasicMaterial({ 
                color: 0xffffff, 
                wireframe: true, 
                transparent: true, 
                opacity: 0.05 
            });
            coreGroup.add(new THREE.Mesh(innerCoreGeom, innerCoreMat));

            // "Slinging" Node Logic
            const nodeGeom = new THREE.BoxGeometry(0.35, 0.35, 0.35);
            const whiteMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.6 });
            
            for(let i=0; i < 15; i++) {
                const node = new THREE.Mesh(nodeGeom, whiteMat);
                // Randomized orbital properties
                slingers.push({ 
                    mesh: node, 
                    radius: 9 + Math.random() * 6, 
                    speed: 0.005 + Math.random() * 0.015, 
                    angle: Math.random() * Math.PI * 2,
                    tilt: Math.random() * Math.PI,
                    tiltSpeed: (Math.random() - 0.5) * 0.02
                });
                scene.add(node);
            }

            // Orbital Rings
            const ringGeom = new THREE.TorusGeometry(12, 0.015, 16, 100);
            const ring1 = new THREE.Mesh(ringGeom, coreMat);
            const ring2 = new THREE.Mesh(ringGeom, coreMat);
            ring1.rotation.x = Math.PI / 4;
            ring2.rotation.y = Math.PI / 4;
            coreGroup.add(ring1);
            coreGroup.add(ring2);

            scene.add(coreGroup);

            camera.position.z = 24;

            window.addEventListener('resize', onWindowResize);
            animate();
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            const time = Date.now() * 0.001;
            
            // Core Rotation
            coreGroup.rotation.y += 0.002;
            coreGroup.rotation.x = Math.sin(time * 0.2) * 0.1;

            // Slinging Particles Logic
            slingers.forEach(s => {
                s.angle += s.speed;
                s.tilt += s.tiltSpeed;
                
                s.mesh.position.x = Math.cos(s.angle) * s.radius;
                s.mesh.position.y = Math.sin(s.tilt) * (s.radius * 0.5);
                s.mesh.position.z = Math.sin(s.angle) * s.radius;
                
                s.mesh.rotation.x += 0.05;
                s.mesh.rotation.y += 0.05;
            });

            // Smooth Scroll Displacement
            const scrollY = window.pageYOffset;
            coreGroup.position.y = scrollY * 0.012;
            coreGroup.rotation.y += scrollY * 0.0001;

            renderer.render(scene, camera);
        }

        // Section Highlighting
        const tabs = document.querySelectorAll('.nav-item');
        window.addEventListener('scroll', () => {
            let current = "";
            const sections = document.querySelectorAll("section");
            sections.forEach(s => {
                if (pageYOffset >= s.offsetTop - 400) current = s.getAttribute("id");
            });
            tabs.forEach(t => {
                t.classList.remove('active');
                if(t.getAttribute('href').includes(current)) t.classList.add('active');
            });
        });

        window.onload = init;
    </script>
</body>
</html>
